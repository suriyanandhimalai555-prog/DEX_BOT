# Copy this file to .env in the same folder (backend/.env) and fill in real values.
# The API loads dotenv from the current working directory when you run `npm run dev` from backend/.

# Server
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
BSC_CHAIN_ID=56

# MongoDB
MONGODB_URI=mongodb://localhost:27017/dex-bot-platform
# If Atlas mongodb+srv fails with querySrv ECONNREFUSED (often on Windows), uncomment:
# MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4

# Redis
REDIS_URL=redis://localhost:6379

# JWT (32+ random characters each)
JWT_ACCESS_SECRET=replace_with_32_or_more_random_characters_here
JWT_REFRESH_SECRET=replace_with_32_or_more_random_characters_here

# Private key encryption — exactly 64 hex characters (32 bytes)
ENCRYPTION_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Alchemy BSC RPC (also used by GET /api/holdings/:walletAddress for token balances / metadata)
ALCHEMY_BSC_MAINNET_URL=https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_BSC_TESTNET_URL=https://bnb-testnet.g.alchemy.com/v2/YOUR_KEY

# Telegram Bot API
TELEGRAM_BOT_TOKEN=0000000000:replace_with_your_bot_token

# PancakeSwap on BSC (defaults — change only if you know what you are doing)
PANCAKE_V2_ROUTER=0x10ED43C718714eb63d5aA57B78B54704E256024E
PANCAKE_V3_ROUTER=0x13f4EA83D0bd40E75C8222255bc855a974568Dd4
PANCAKE_V3_QUOTER=0xB048Bbc1Ee6b733FFfCFb9e9CeF7375518e25997
WBNB_ADDRESS=0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c

# Trade limits (USD per trade, recalculated to BNB via CoinGecko)
DEFAULT_TRADE_LIMIT_USD=1.0
MAX_TRADE_LIMIT_USD=10000.0

# Seeded when no users exist (change immediately in production)
ADMIN_EMAIL=admin@dexbot.local
ADMIN_PASSWORD=Admin@123456

# BNB price polling
BNB_PRICE_POLL_INTERVAL_MS=60000
BNB_PRICE_FALLBACK_USD=300
