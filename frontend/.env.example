# Copy this file to .env in the same folder (frontend/.env).
# Only variables prefixed with VITE_ are exposed to the browser.

# ---------------------------------------------------------------------------
# Recommended: local dev with `npm run dev` (Vite proxy)
# ---------------------------------------------------------------------------
# Leave VITE_API_BASE_URL unset so the app calls /api on the same origin;
# Vite proxies /api to the backend (see vite.config.ts). Socket.io uses
# VITE_DEV_BACKEND_URL directly in dev to avoid noisy Vite WS proxy errors.
#
# If your API runs on a non-default host/port, set the proxy target only
# (this file is NOT exposed to the client — Vite reads it at build/dev time):
VITE_DEV_BACKEND_URL=http://localhost:4000

# Wagmi — BSC RPC (Alchemy preferred; fallback is public BSC seed in wagmi.config)
VITE_ALCHEMY_BSC_URL=

# WalletConnect v2 — project id from https://cloud.reown.com (wallet QR / mobile)
VITE_WALLETCONNECT_PROJECT_ID=e50271e926383ca1186d9255c4681e7c

# ---------------------------------------------------------------------------
# Optional: frontend talks directly to the API (no Vite proxy)
# ---------------------------------------------------------------------------
# Use this when you open the built `dist/` from another server, or when
# debugging CORS/cookies against a remote backend. Then set BOTH:
# VITE_API_BASE_URL=http://localhost:4000/api
# VITE_SOCKET_URL=http://localhost:4000
#
# Cookies + CORS: backend FRONTEND_ORIGIN must match the URL where you open
# the React app (e.g. http://localhost:5173).
